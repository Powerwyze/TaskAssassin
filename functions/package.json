{
    "name": "taskassassin-functions",
    "version": "1.0.0",
    "description": "Firebase Cloud Functions for TaskAssassin push notifications",
    "main": "lib/index.js",
    "scripts": {
        "build": "tsc",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "18"
    },
    "dependencies": {
        "firebase-admin": "^12.0.0",
        "firebase-functions": "^4.5.0",
        "web-push": "^3.6.6"
    },
    "devDependencies": {
        "@types/web-push": "^3.6.3",
        "typescript": "^5.3.0"
    },
    "private": true
}