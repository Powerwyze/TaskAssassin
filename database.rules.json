{
    "rules": {
        "users": {
            ".read": "auth != null",
            "$uid": {
                ".write": "$uid === auth.uid",
                "profile": {
                    ".write": "$uid === auth.uid"
                }
            }
        },
        "userStats": {
            "$uid": {
                ".read": "auth != null",
                ".write": "$uid === auth.uid"
            }
        },
        "achievements": {
            "$uid": {
                ".read": "auth != null",
                ".write": "$uid === auth.uid"
            }
        },
        "notifications": {
            "$uid": {
                ".read": "$uid === auth.uid",
                ".write": "$uid === auth.uid"
            }
        },
        "friends": {
            "$uid": {
                ".read": "$uid === auth.uid",
                "$friendUid": {
                    ".write": "$uid === auth.uid || $friendUid === auth.uid"
                }
            }
        },
        "friendRequests": {
            "$uid": {
                ".read": "$uid === auth.uid",
                "$requestId": {
                    ".write": "$uid === auth.uid || (!data.exists() && newData.exists()) || (data.child('fromUid').val() === auth.uid && !newData.exists())"
                }
            }
        },
        "sentFriendRequests": {
            "$uid": {
                ".read": "$uid === auth.uid",
                "$requestId": {
                    ".write": "$uid === auth.uid || (data.child('toUid').val() === auth.uid && !newData.exists())"
                }
            }
        },
        "userMessages": {
            "$uid": {
                ".read": "$uid === auth.uid",
                "$messageId": {
                    ".write": "$uid === auth.uid || (!data.exists() && newData.exists() && newData.child('fromUid').val() === auth.uid)"
                }
            }
        },
        "tasks": {
            "$uid": {
                ".read": "$uid === auth.uid",
                "$taskId": {
                    ".write": "$uid === auth.uid || (!data.exists() && newData.exists() && newData.child('fromUid').val() === auth.uid)"
                }
            }
        },
        "bugs": {
            ".read": "auth != null",
            ".write": "auth != null"
        }
    }
}