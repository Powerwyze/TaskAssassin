# Questime Flutter build configuration
# Pass these with --dart-define for release builds when overriding defaults.

SUPABASE_URL=https://gbwzsxjromwefuopvzfg.supabase.co
SUPABASE_ANON_KEY=
ENABLE_PUSH=false

# Questime server-side secrets
# These values belong in Supabase Edge Function secrets, not in Flutter assets.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ALLOWED_ORIGIN=*
MAX_REQUEST_BYTES=12000
MAX_IMAGE_BYTES=5242880
MAX_OUTPUT_TOKENS=900
OPENAI_TIMEOUT_MS=45000
